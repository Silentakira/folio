---
const steps = [
	{
		number: '01',
		title: 'Understand',
		description: 'Deep dive into your vision, goals, and the story you want to tell. Every project begins with listening.'
	},
	{
		number: '02',
		title: 'Define',
		description: 'Shape the concept into clear direction. We establish the aesthetic, mood, and technical approach.'
	},
	{
		number: '03',
		title: 'Design',
		description: 'The creative work comes alive. Photos are taken, visuals are crafted, and the narrative unfolds.'
	},
	{
		number: '04',
		title: 'Refine',
		description: 'Perfecting every detail. Color grading, retouching, and ensuring everything meets our exacting standards.'
	},
	{
		number: '05',
		title: 'Deliver',
		description: 'Final assets ready for your use. Beautiful, impactful work that tells your story.'
	}
];
---

<section class="process" id="process">
	<div class="process-header scroll-animate">
		<p class="section-label">Process</p>
		<h2>How we work together.</h2>
	</div>

	<div class="process-list">
		{steps.map((step) => (
			<div class="process-step scroll-animate">
				<div class="step-heading-wrapper">
					<h3 class="step-title">{step.title}</h3>
				</div>
				<div class="step-content">
					<span class="step-number">{step.number}</span>
					<p class="step-description">{step.description}</p>
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.process {
		padding: clamp(80px, 15vw, 160px) clamp(20px, 6vw, 120px);
		border-top: 1px solid var(--border);
	}

	.process-header {
		margin-bottom: 80px;
	}

	.process-header h2 {
		font-size: clamp(2rem, 4vw, 3.5rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.section-label {
		margin-bottom: 20px;
		color: var(--pink);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.dark .section-label {
		color: var(--accent);
	}

	/* Container for all steps */
	.process-list {
		display: flex;
		flex-direction: column;
		gap: 48px;
		max-width: 900px;
		margin: 0 auto;
	}

	/* Each step row */
	.process-step {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 48px;
		align-items: start;
		padding: 32px 0;
		position: relative;
	}

	/* Left column - heading (left-aligned, positioned above connected text) */
	.step-heading-wrapper {
		position: relative;
		display: flex;
		align-items: flex-start;
	}

	.step-title {
		color: #22c55e;
		font-size: 1.75rem;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin: 0;
		text-align: left;
		/* Positioned slightly above the connected text */
		transform: translateY(-8px);
	}

	/* Right column - number + description */
	.step-content {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.step-number {
		color: #999999;
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		font-variant-numeric: tabular-nums;
	}

	.step-description {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.7;
		margin: 0;
		max-width: 420px;
	}

	.scroll-animate {
		opacity: 0;
		transform: translateY(24px);
		transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.scroll-animate.visible {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 768px) {
		.process {
			padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
		}

		.process-header {
			margin-bottom: 48px;
		}

		.process-list {
			gap: 32px;
		}

		.process-step {
			grid-template-columns: 1fr;
			gap: 20px;
			padding: 24px 0;
		}

		.step-title {
			font-size: 1.5rem;
			transform: none;
		}

		.step-description {
			max-width: 100%;
		}
	}
</style>

<script>
	const observerOptions = {
		threshold: 0.1,
		rootMargin: '0px 0px -50px 0px'
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('visible');
			}
		});
	}, observerOptions);

	document.querySelectorAll('.scroll-animate').forEach(el => {
		observer.observe(el);
	});
</script>
