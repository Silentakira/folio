<section class="about" id="about">
	<div class="about-container">
		<div class="about-content scroll-animate">
			<p class="greeting">Hi there,</p>
			<p>
				I'm Akira, a UI/UX designer and intern at Boutik. I like work that feels calm on the
				surface and intentional underneath: simple systems, useful motion, and interfaces that
				help people decide without needing to think too hard.
			</p>
			<p>
				I was the main designer on <strong>Miau Studios</strong>, the project that most feels
				like me right now. It taught me that minimal design does not need to be cold. It can
				be clean, funny, sharp, and still very practical.
			</p>
			<p>
				I am studying Design de Interfaces e Multimedia at ESAD and taking freelance projects
				for businesses that need clearer branding, better websites, or a design audit before
				they waste more time guessing.
			</p>
		</div>
	</div>
</section>

<style>
	.about {
		padding: 120px 24px;
		background: var(--text-color);
		color: var(--bg-color);
		position: relative;
		z-index: 1;
	}

	.about-container {
		max-width: 740px;
		margin: 0 auto;
	}

	.about-content {
		font-size: clamp(1.1rem, 2vw, 1.6rem);
		line-height: 1.8;
	}

	.greeting {
		font-size: clamp(1.3rem, 2.5vw, 2rem);
		font-weight: 700;
		margin-bottom: 32px;
		color: var(--accent);
	}

	.about-content p + p {
		margin-top: 24px;
	}

	.about-content strong {
		color: var(--accent);
		font-weight: 600;
	}

	.scroll-animate {
		opacity: 0;
		transform: translateY(40px);
		transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.scroll-animate.visible {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	const observerOptions = {
		threshold: 0.1,
		rootMargin: '0px 0px -50px 0px'
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('visible');
			}
		});
	}, observerOptions);

	document.querySelectorAll('.scroll-animate').forEach(el => {
		observer.observe(el);
	});
</script>
