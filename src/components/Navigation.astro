---
---

<nav class="nav">
	<a href="/" class="nav-logo interactive cursor-interact" data-cursor="HOME">
		<span class="logo-mark">AU</span>
		<span>Akira Uriel</span>
	</a>

	<div class="nav-links">
		<a href="#work" class="nav-link interactive cursor-interact" data-cursor="VIEW">Work</a>
		<a href="#about" class="nav-link interactive cursor-interact" data-cursor="VIEW">About</a>
		<a href="#services" class="nav-link interactive cursor-interact" data-cursor="VIEW">Services</a>
		<a href="#contact" class="nav-link interactive cursor-interact" data-cursor="VIEW">Contact</a>
	</div>

	<button id="theme-toggle" class="theme-toggle interactive cursor-interact" data-cursor="THEME" aria-label="Toggle theme">
		<span class="theme-icon">○</span>
	</button>
</nav>

<style>
	.nav {
		position: fixed;
		top: 24px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(calc(100% - 32px), 1200px);
		padding: 12px 20px;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(20px);
		border: 1px solid var(--border);
		border-radius: 100px;
		z-index: 1000;
	}

	.dark .nav {
		background: rgba(10, 10, 10, 0.85);
		border-color: var(--border);
	}

	.nav-logo {
		display: flex;
		align-items: center;
		gap: 10px;
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--text-color);
	}

	.logo-mark {
		display: grid;
		place-items: center;
		width: 32px;
		height: 32px;
		background: var(--yellow);
		color: #000;
		border-radius: 50%;
		font-size: 0.75rem;
		font-weight: 800;
	}

	.dark .logo-mark {
		background: var(--accent);
		color: white;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 32px;
	}

	.nav-link {
		color: var(--text-muted);
		font-weight: 500;
		font-size: 0.9rem;
		transition: color 0.2s ease;
		position: relative;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 50%;
		transform: translateX(-50%) scaleX(0);
		width: 100%;
		height: 1px;
		background: var(--text-color);
		transition: transform 0.3s ease;
	}

	.dark .nav-link::after {
		background: var(--accent);
	}

	.nav-link:hover {
		color: var(--text-color);
	}

	.nav-link:hover::after {
		transform: translateX(-50%) scaleX(1);
	}

	.theme-toggle {
		display: grid;
		place-items: center;
		width: 36px;
		height: 36px;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 50%;
		font-size: 16px;
		transition: all 0.3s ease;
		color: var(--text-color);
	}

	.theme-toggle:hover {
		background: var(--text-color);
		color: var(--bg-color);
		transform: rotate(180deg);
	}

	@media (max-width: 640px) {
		.nav {
			top: 16px;
			padding: 10px 16px;
		}

		.nav-logo span:last-child {
			display: none;
		}

		.nav-links {
			display: none;
		}
	}
</style>

<script>
	const themeToggle = document.getElementById('theme-toggle');
	const themeIcon = themeToggle?.querySelector('.theme-icon');

	// Load saved theme
	const savedTheme = localStorage.getItem('theme');
	const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

	if (savedTheme === 'dark' || (!savedTheme && systemDark)) {
		document.documentElement.classList.add('dark');
		themeIcon!.textContent = '●';
	}

	// Toggle theme
	themeToggle?.addEventListener('click', () => {
		const isDark = document.documentElement.classList.toggle('dark');
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
		themeIcon!.textContent = isDark ? '●' : '○';
	});
</script>
