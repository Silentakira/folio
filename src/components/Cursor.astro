---
// Smart cursor that adapts to background colors
---

<div class="custom-cursor" id="customCursor"></div>

<style>
	.custom-cursor {
		position: fixed;
		top: 0;
		left: 0;
		width: 20px;
		height: 20px;
		border: 2px solid #09090b;
		border-radius: 50%;
		pointer-events: none;
		z-index: 10000;
		opacity: 0;
		transition: width 0.2s ease, height 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
		will-change: transform;
	}

	.custom-cursor.active {
		opacity: 1;
	}

	/* Light background hover */
	.custom-cursor.hover-light {
		background-color: #e4e4e7;
		border-color: #e4e4e7;
	}

	/* Dark background hover */
	.custom-cursor.hover-dark {
		background-color: #f8f8f8;
		border-color: #f8f8f8;
	}

	@media (max-width: 768px) {
		.custom-cursor {
			display: none;
		}

		body {
			cursor: auto !important;
		}
	}
</style>

<script>
	const cursor = document.getElementById('customCursor');

	if (cursor) {
		let mouseX = 0;
		let mouseY = 0;
		let cursorX = 0;
		let cursorY = 0;
		let firstMove = true;

		document.addEventListener('mousemove', (e: MouseEvent) => {
			mouseX = e.clientX;
			mouseY = e.clientY;

			if (firstMove) {
				cursor.classList.add('active');
				firstMove = false;
			}

			// Check what's under cursor and update state
			updateCursorState(e.clientX, e.clientY);
		});

		function updateCursorState(x: number, y: number) {
			const element = document.elementFromPoint(x, y);
			if (!element) return;

			// Check if hovering over interactive element
			const isInteractive = element.matches('a, button, .cursor-interact') ||
			               element.closest('a, button, .cursor-interact');

			if (isInteractive) {
				// Get background color of element
				const styles = window.getComputedStyle(element);
				const bgColor = styles.backgroundColor;

				// Determine if background is light or dark
				const isLightBg = isLightBackground(bgColor);

				// Remove old classes
				cursor.classList.remove('hover-light', 'hover-dark');

				// Add appropriate class
				if (isLightBg) {
					cursor.classList.add('hover-light');
				} else {
					cursor.classList.add('hover-dark');
				}
			} else {
				// Not hovering over interactive element
				cursor.classList.remove('hover-light', 'hover-dark');
			}
		}

		function isLightBackground(bgColor: string): boolean {
			// Check if background is white/light colored
			if (bgColor === 'rgba(0, 0, 0, 0)' || bgColor === 'transparent') {
				// Check parent's background
				return false; // Will use body background
			}

			// Parse RGB values
			const rgbMatch = bgColor.match(/^rgb\((\d+),\s*(\d+),\s*(\d+)\)$/);
			if (rgbMatch) {
				const r = parseInt(rgbMatch[1]);
				const g = parseInt(rgbMatch[2]);
				const b = parseInt(rgbMatch[3]);

				// Calculate brightness
				const brightness = (r * 299 + g * 587 + b * 114) / 1000;
				return brightness > 128;
			}

			// Parse RGBA values
			const rgbaMatch = bgColor.match(/^rgba\((\d+),\s*(\d+),\s*(\d+),\s*([\d.]+)\)$/);
			if (rgbaMatch) {
				const r = parseInt(rgbaMatch[1]);
				const g = parseInt(rgbaMatch[2]);
				const b = parseInt(rgbaMatch[3]);
				const a = parseFloat(rgbaMatch[4]);

				if (a < 0.5) {
					return false; // Too transparent
				}

				const brightness = (r * 299 + g * 587 + b * 114) / 1000;
				return brightness > 128;
			}

			// Check hex colors
			const hexMatch = bgColor.match(/^#([0-9a-f]{3}){1,2}$/i);
			if (hexMatch) {
				const hex = hexMatch[1];
				const r = parseInt(hex[0] + hex[0], 16);
				const g = parseInt(hex[1] + hex[1], 16);
				const b = parseInt(hex[2] + hex[2], 16);

				const brightness = (r * 299 + g * 587 + b * 114) / 1000;
				return brightness > 128;
			}

			return false;
		}

		function animate() {
			const dx = mouseX - cursorX;
			const dy = mouseY - cursorY;

			cursorX += dx * 0.15;
			cursorY += dy * 0.15;

			cursor.style.transform = `translate(${cursorX}px, ${cursorY}px)`;

			requestAnimationFrame(animate);
		}

		animate();

		// Re-run periodically for dynamic elements
		setInterval(() => {
			setupHoverEffects();
		}, 2000);

		// Setup hover effects
		function setupHoverEffects() {
			const interactives = document.querySelectorAll('a, button, .cursor-interact');

			interactives.forEach((el) => {
				// Remove old listeners
				el.removeEventListener('mouseenter', updateCursorState);
				el.removeEventListener('mouseleave', clearCursorState);

				// Add new listeners
				el.addEventListener('mouseenter', () => {
					// Cursor state will be updated in mousemove
				});

				el.addEventListener('mouseleave', () => {
					cursor?.classList.remove('hover-light', 'hover-dark');
				});
			});
		}

		function clearCursorState() {
			cursor?.classList.remove('hover-light', 'hover-dark');
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setupHoverEffects);
		} else {
			setupHoverEffects();
		}
	}
</script>
