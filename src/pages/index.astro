	<script>
		// Smooth scroll settings
		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const isMobile = window.matchMedia('(max-width: 768px)').matches;
		const smoothWrapper = document.getElementById('smooth-wrapper');

		// Enable smooth scroll only on desktop without reduced motion
		if (!prefersReduced && !isMobile && smoothWrapper) {
			let targetY = 0;
			let currentY = 0;
			const ease = 0.1;

			function lerp(a, b, t) {
				return a + (b - a) * t;
			}

			function setBodyHeight() {
				document.body.style.height = smoothWrapper.scrollHeight + 'px';
			}

			// Cache animated elements
			const animatedElements = document.querySelectorAll('.animate-in');
			let lastCheckTime = 0;

			function smoothScroll() {
				targetY = window.scrollY;
				currentY = lerp(currentY, targetY, ease);

				if (Math.abs(targetY - currentY) < 0.05) {
					currentY = targetY;
				}

				smoothWrapper.style.transform = `translateY(${-currentY}px)`;

				// Only check animations every 100ms instead of every frame
				const now = Date.now();
				if (now - lastCheckTime > 100) {
					const viewportHeight = window.innerHeight;
					animatedElements.forEach((item) => {
						const rect = item.getBoundingClientRect();
						const isBelowViewport = rect.top > viewportHeight * 0.75;
						const isAboveViewport = rect.bottom < 0;

						if (isBelowViewport || isAboveViewport) {
							item.classList.remove('visible');
						} else {
							item.classList.add('visible');
						}
					});
					lastCheckTime = now;
				}

				requestAnimationFrame(smoothScroll);
			}

			// Initialize smooth scroll
			setBodyHeight();
			smoothScroll();

			// Update body height on resize (debounced)
			let resizeTimeout;
			window.addEventListener('resize', () => {
				clearTimeout(resizeTimeout);
				resizeTimeout = setTimeout(setBodyHeight, 150);
			});
		} else {
			// Standard scroll for mobile and reduced motion
			const observerOptions = {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting && !entry.target.classList.contains('visible')) {
						entry.target.classList.add('visible');
						observer.unobserve(entry.target);
					}
				});
			}, observerOptions);

			// Observe all elements with .animate-in class
			function setupAnimations() {
				document.querySelectorAll('.animate-in').forEach(el => {
					observer.observe(el);
				});
			}

			// Run on DOM ready
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', setupAnimations);
			} else {
				setupAnimations();
			}
		}
	</script>
