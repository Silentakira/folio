---
import Layout from '../layouts/Layout.astro';
import Cursor from '../components/Cursor.astro';
import AsciiTextAnimation from '../components/AsciiTextAnimation.astro';
---

<Layout title="Home">
	<Cursor />
	<AsciiTextAnimation />

	<div id="smooth-wrapper">
		<main>
		<section class="hero">
			<div class="container">
				<p class="overline animate-in">UI/UX & Brand Designer</p>

				<h1 class="animate-in">
					<span class="scramble-text">I design brands and interfaces that <span class="text-accent">work</span>.</span>
				</h1>

				<p class="description animate-in">
					UI/UX & brand design. Logos, visual identity systems, websites that people actually understand how to use.
				</p>

				<div class="actions animate-in">
					<a href="#work" class="btn-primary cursor-interact">See the work</a>
					<a href="mailto:silencedakira@gmail.com" class="btn-secondary cursor-interact">Get in touch</a>
				</div>
			</div>
		</section>

		<section class="work" id="work">
			<div class="container">
				<p class="section-label animate-in">Selected Work</p>
				<h2 class="section-title animate-in">Recent Projects</h2>
				<div class="projects">
					<a href="/work/miau-studios" class="project animate-in cursor-interact">
						<div class="project-header">
							<span class="project-number">01</span>
							<div class="project-meta">Miau Studios · Co-Founder & Designer</div>
						</div>
						<h3>Miau Studios</h3>
						<p>A school project that became real. Joana Soares and I created an indie game studio with skate-inspired aesthetics and a game to match.</p>
						<div class="project-tags">
							<span>Brand System</span>
							<span>Art Direction</span>
							<span>Game Design</span>
						</div>
					</a>

					<a href="/work/vibe" class="project animate-in cursor-interact">
						<div class="project-header">
							<span class="project-number">02</span>
							<div class="project-meta">Vibe · Brand Designer</div>
						</div>
						<h3>Vibe</h3>
						<p>Neobrutalist design agency that fixes problems that hurt both your aesthetic and your conversion rates.</p>
						<div class="project-tags">
							<span>Branding</span>
							<span>Agency Identity</span>
							<span>Conversion</span>
						</div>
					</a>

					<a href="/work/nonna-co" class="project animate-in cursor-interact">
						<div class="project-header">
							<span class="project-number">03</span>
							<div class="project-meta">NONNA & CO · Logo Designer</div>
						</div>
						<h3>NONNA & CO</h3>
						<p>Concept pasta store logo design with plans to expand into full brand identity.</p>
						<div class="project-tags">
							<span>Logo Design</span>
							<span>Brand Concept</span>
						</div>
					</a>
				</div>
			</div>
		</section>

		<section class="about">
			<div class="container">
				<p class="section-label animate-in">About</p>
				<h2 class="section-title animate-in">About me</h2>
				<div class="about-content">
					<p class="animate-in">
						I'm <span class="text-accent">Akira Uriel</span> — UI/UX and brand designer based in Braga, Portugal.
					</p>
					<p class="animate-in">
						I help businesses fix weak branding and confusing interfaces. logos, visual identity systems, UI/UX design that makes sense to users.
					</p>
					<p class="animate-in">
						Currently interning at Boutik Studio. Taking freelance projects for brand identity, UI/UX design, and design audits.
					</p>
				</div>
			</div>
		</section>

		<section class="process">
			<div class="container">
				<p class="section-label animate-in">Process</p>
				<h2 class="animate-in">How I work</h2>
				<div class="process-steps">
					<div class="process-step animate-in">
						<span class="step-number">01</span>
						<h3><span class="text-accent">Understand</span></h3>
						<p>I learn what your business needs and what your users are struggling with.</p>
					</div>

					<div class="process-step animate-in">
						<span class="step-number">02</span>
						<h3><span class="text-accent">Define</span></h3>
						<p>We agree on what to build and what success looks like.</p>
					</div>

					<div class="process-step animate-in">
						<span class="step-number">03</span>
						<h3><span class="text-accent">Design</span></h3>
						<p>I create the work — logos, UI, systems — with clear reasoning behind every decision.</p>
					</div>

					<div class="process-step animate-in">
						<span class="step-number">04</span>
						<h3><span class="text-accent">Refine</span></h3>
						<p>We review what works, fix what doesn't, and polish the details.</p>
					</div>

					<div class="process-step animate-in">
						<span class="step-number">05</span>
						<h3><span class="text-accent">Deliver</span></h3>
						<p>You get final files ready to launch, with follow-up support if needed.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="services">
			<div class="container">
				<p class="section-label animate-in">Services</p>
				<h2 class="section-title animate-in">What I can help with.</h2>
				<div class="services-list">
					<div class="service-item animate-in">
						<div class="service-header">
							<span class="service-number">01</span>
							<h3>UI/UX Design</h3>
						</div>
						<p>Web and mobile interfaces built around how people actually make decisions.</p>
					</div>

					<div class="service-item animate-in">
						<div class="service-header">
							<span class="service-number">02</span>
							<h3>Brand Design</h3>
						</div>
						<p>Logos, identity systems, and visual rules that make a business memorable and consistent.</p>
					</div>

					<div class="service-item animate-in">
						<div class="service-header">
							<span class="service-number">03</span>
							<h3>Design Audits</h3>
						</div>
						<p>A clear read on what's confusing your users, what's costing you conversions, and what to fix first.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="contact" id="contact">
			<div class="container">
				<p class="section-label animate-in">Contact</p>
				<h2 class="section-title animate-in">Your design should be easy to choose. Let's make sure it is.</h2>
				<a href="mailto:silencedakira@gmail.com" class="email-link cursor-interact animate-in">silencedakira@gmail.com</a>
			</div>
		</section>

		<footer class="footer">
			<div class="container">
				<div class="footer-content">
					<div class="social-links">
						<a href="https://www.behance.net/akirauriel" target="_blank" rel="noopener" class="social-link cursor-interact" aria-label="Behance">
							<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14h-8.027c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988h-6.466v-14.967h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zm-3.466-8.988h3.584c2.508 0 2.906-3-.312-3h-3.272v3zm3.391 3h-3.391v3.016h3.341c3.055 0 2.868-3.016.05-3.016z"/></svg>
						</a>
						<a href="https://x.com/ArthurK19424" target="_blank" rel="noopener" class="social-link cursor-interact" aria-label="Twitter/X">
							<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
							</svg>
						</a>
						<a href="https://www.instagram.com/a.kaye_design?igsh=MXBzcW15anhjYmh2Ng%3D%3D&utm_source=qr" target="_blank" rel="noopener" class="social-link cursor-interact" aria-label="Instagram">
							<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
								<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
							</svg>
						</a>
					</div>
					<p>© 2026 Akira Uriel · UI/UX & Branding · Braga, Portugal</p>
				</div>
			</div>
		</footer>
	</main>
	</div>

	<style>
		.container {
			max-width: 900px;
			margin: 0 auto;
			padding: 0 24px;
		}

		/* Base animation state */
		.animate-in {
			opacity: 0;
			transform: translateY(24px);
			transition: opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
			            transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
			will-change: opacity, transform;
		}

		.animate-in.visible {
			opacity: 1;
			transform: translateY(0);
		}

		/* Hero section stagger */
		.hero .overline.animate-in {
			transform: translateY(10px);
			transition-delay: 0ms;
		}

		.hero h1.animate-in {
			transform: translateY(20px);
			transition-duration: 0.6s;
			transition-delay: 80ms;
		}

		.hero .description.animate-in {
			transform: translateY(10px);
			transition-delay: 80ms;
		}

		.hero .actions.animate-in {
			transform: translateY(8px);
			transition-delay: 160ms;
		}

		/* Projects - stagger cards */
		.project.animate-in {
			transform: translateY(24px);
		}

		.project:nth-child(1).animate-in {
			transition-delay: 0s;
		}

		.project:nth-child(2).animate-in {
			transition-delay: 0.12s;
		}

		.project:nth-child(3).animate-in {
			transition-delay: 0.24s;
		}

		/* Tags animate after parent card */
		.project-tags {
			opacity: 0;
			transition: opacity 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
		}

		.project.visible .project-tags {
			opacity: 1;
			transition-delay: 0.15s;
		}

		/* About - sequential paragraphs */
		.about-content p.animate-in {
			transform: translateY(16px);
		}

		.about-content p:nth-child(1).animate-in {
			transition-delay: 0s;
		}

		.about-content p:nth-child(2).animate-in {
			transition-delay: 0.1s;
		}

		.about-content p:nth-child(3).animate-in {
			transition-delay: 0.2s;
		}

		/* Services - stagger vertically */
		.service-item.animate-in {
			transform: translateY(16px);
		}

		.service-item:nth-child(1).animate-in {
			transition-delay: 0ms;
		}

		.service-item:nth-child(2).animate-in {
			transition-delay: 100ms;
		}

		.service-item:nth-child(3).animate-in {
			transition-delay: 200ms;
		}

		/* Contact stagger */
		.contact .section-label.animate-in {
			transition-delay: 0ms;
		}

		.contact h2.animate-in {
			transform: translateY(16px);
			transition-delay: 80ms;
		}

		.contact .email-link.animate-in {
			transition-delay: 160ms;
		}

		/* Respect reduced motion */
		@media (prefers-reduced-motion: reduce) {
			* {
				transition: none !important;
				animation: none !important;
			}

			.animate-in {
				opacity: 1;
				transform: none !important;
			}

			.project-tags {
				opacity: 1 !important;
			}

			.service-number {
				opacity: 1 !important;
			}
		}

		/* Hero */
		.hero {
			min-height: 90vh;
			display: flex;
			align-items: center;
			padding: 120px 0;
		}

		.overline {
			color: #64748b;
			font-size: 0.875rem;
			font-weight: 600;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			margin-bottom: 24px;
		}

		.hero h1 {
			font-family: 'Space Grotesk', sans-serif;
			font-size: clamp(2.5rem, 6vw, 4rem);
			font-weight: 700;
			line-height: 1.1;
			letter-spacing: -0.02em;
			margin-bottom: 24px;
			color: #09090b;
		}

		.text-outline {
			color: transparent;
			-webkit-text-stroke: 2px #09090b;
			text-stroke: 2px #09090b;
			font-weight: 800;
		}

		.text-accent {
			color: var(--accent-green);
			font-weight: 800;
		}

		.description {
			font-size: 1.125rem;
			color: #64748b;
			max-width: 580px;
			line-height: 1.7;
			margin-bottom: 40px;
		}

		.actions {
			display: flex;
			gap: 32px;
			flex-wrap: wrap;
			align-items: center;
		}

		/* Buttons */
		.btn-primary,
		.btn-secondary,
		.email-link {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 8px 16px;
			font-size: 0.95rem;
			font-weight: 500;
			border: none;
			background: transparent;
			position: relative;
			border-radius: 6px;
			overflow: hidden;
			z-index: 1;
		}

		.btn-primary {
			color: #09090b;
			transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
		}

		.btn-primary::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: linear-gradient(135deg, #09090b 0%, var(--accent-green) 100%);
			transform: scaleX(0);
			transform-origin: right;
			transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
			z-index: -1;
		}

		.btn-primary:hover::before {
			transform: scaleX(1);
			transform-origin: left;
		}

		.btn-primary:hover {
			color: #ffffff;
			transition-delay: 0.05s;
		}

		.btn-secondary {
			color: #64748b;
			transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
		}

		.btn-secondary::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: var(--accent-green);
			transform: scaleX(0);
			transform-origin: right;
			transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
			z-index: -1;
		}

		.btn-secondary:hover::before {
			transform: scaleX(1);
			transform-origin: left;
		}

		.btn-secondary:hover {
			color: #ffffff;
			transition-delay: 0.05s;
		}

		.btn-secondary:hover {
			color: #ffffff;
			transition-delay: 0.05s;
		}

		/* Sections */
		.work,
		.about,
		.services,
		.contact {
			padding: 100px 0;
			border-top: 1px solid #e4e4e7;
		}

		.section-label {
			color: #64748b;
			font-size: 0.875rem;
			font-weight: 600;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			margin-bottom: 16px;
		}

		.section-title {
			font-family: 'Space Grotesk', sans-serif;
			font-size: clamp(2rem, 4vw, 2.5rem);
			font-weight: 700;
			letter-spacing: -0.02em;
			margin-bottom: 32px;
			color: #09090b;
			line-height: 1.2;
		}

		/* Projects */
		.projects {
			display: flex;
			flex-direction: column;
			gap: 60px;
		}

		.project {
			display: flex;
			flex-direction: column;
			gap: 16px;
			text-decoration: none;
			color: inherit;
			transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
			position: relative;
		}

		.project::after {
			content: '';
			position: absolute;
			bottom: -8px;
			left: 0;
			width: 0;
			height: 2px;
			background: var(--accent-green);
			transition: width 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
			border-radius: 2px;
		}

		.project:hover::after {
			width: 100%;
		}

		.project:hover h3 {
			color: var(--accent-green);
			transform: translateX(4px);
		}

		.project h3 {
			transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1),
			             transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
		}

		.project-header {
			display: flex;
			align-items: center;
			gap: 16px;
		}

		.project-number {
			font-size: 0.875rem;
			font-weight: 600;
			color: #64748b;
		}

		.project-meta {
			font-size: 0.875rem;
			color: #64748b;
		}

		.project h3 {
			font-size: 1.75rem;
			font-weight: 600;
			letter-spacing: -0.02em;
		}

		.project p {
			color: #64748b;
			line-height: 1.7;
			max-width: 600px;
		}

		.project-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
			margin-top: 16px;
		}

		.project-tags span {
			padding: 6px 14px;
			background: #fafafa;
			color: #64748b;
			border-radius: 100px;
			font-size: 0.8rem;
			font-weight: 500;
		}

		/* About */
		.about-content {
			display: flex;
			flex-direction: column;
			gap: 24px;
		}

		.about-content p {
			color: #64748b;
			font-size: 1.05rem;
			line-height: 1.8;
			max-width: 720px;
		}

		/* Process */
		.process {
			padding: 100px 0;
			border-top: 1px solid #e4e4e7;
		}

		.process h2 {
			font-size: 2rem;
			font-weight: 700;
			letter-spacing: -0.02em;
			margin-bottom: 48px;
		}

		.process-steps {
			display: flex;
			flex-direction: row;
			gap: 48px;
			justify-content: space-between;
		}

		.process-step {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 24px;
			align-items: start;
		}

		.step-number {
			font-size: 0.875rem;
			font-weight: 700;
			color: #e4e4e7;
			letter-spacing: 0.1em;
		}

		.process-step h3 {
			font-size: 1.5rem;
			font-weight: 600;
			letter-spacing: -0.02em;
			margin-bottom: 8px;
		}

		.process-step p {
			color: #64748b;
			font-size: 1rem;
			line-height: 1.7;
			max-width: 580px;
		}

		/* Process stagger animations */
		.process-step.animate-in {
			transform: translateY(16px);
		}

		.process-step:nth-child(1).animate-in {
			transition-delay: 0ms;
		}

		.process-step:nth-child(2).animate-in {
			transition-delay: 80ms;
		}

		.process-step:nth-child(3).animate-in {
			transition-delay: 160ms;
		}

		.process-step:nth-child(4).animate-in {
			transition-delay: 240ms;
		}

		.process-step:nth-child(5).animate-in {
			transition-delay: 320ms;
		}

		/* Services */
			font-size: 2rem;
			font-weight: 700;
			letter-spacing: -0.02em;
			margin-bottom: 48px;
		}

		.services-list {
			display: flex;
			flex-direction: column;
			gap: 48px;
		}

		.service-item {
			display: flex;
			flex-direction: column;
			gap: 12px;
			padding-bottom: 48px;
			border-bottom: 1px solid #e4e4e7;
		}

		.service-item:last-child {
